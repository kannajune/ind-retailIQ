# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=retailiq_db
DB_USER=retailiq_user
DB_PASSWORD=retailiq_password

# AWS Configuration (Optional - for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=retailiq-data-bucket
S3_CSV_PREFIX=uploads/csv/

# SageMaker Configuration (Optional)
SAGEMAKER_ENDPOINT_NAME=retailiq-forecast-endpoint

# Bedrock Configuration (Optional)
BEDROCK_MODEL_ID=anthropic.claude-v2

# Application Configuration
ENVIRONMENT=development
PORT=8000
LOG_LEVEL=INFO

# Security
SECRET_KEY=change_this_in_production_to_a_random_string
